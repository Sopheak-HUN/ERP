# ==============================================================================
# ERP System — single .env source for the whole Docker stack
# Copy to .env (`cp .env.example .env`) and adjust as needed.
# docker-compose pumps these into the backend and frontend containers.
# ==============================================================================

# --- Project ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=erp
APP_NAME=ERP
APP_TIMEZONE=UTC

# --- Host port mappings -------------------------------------------------------
NGINX_HTTP_PORT=8080
NUXT_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MEILI_PORT=7700
HORIZON_PORT=8081

# --- Laravel ------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:${NGINX_HTTP_PORT}
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- PostgreSQL ---------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=erp
DB_USERNAME=erp
DB_PASSWORD=erp_secret_change_me

# --- Redis --------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=phpredis

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# --- MinIO (S3-compatible) ----------------------------------------------------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=erp_minio
AWS_SECRET_ACCESS_KEY=erp_minio_secret_change_me
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=erp
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:${MINIO_API_PORT}
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Meilisearch --------------------------------------------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=erp_meili_master_key_change_me

# --- Sanctum / CORS -----------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:${NUXT_PORT},localhost:${NGINX_HTTP_PORT}
SESSION_DOMAIN=localhost

# --- Mail (dev: log driver) ---------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@erp.local
MAIL_FROM_NAME="${APP_NAME}"

# --- Frontend (Nuxt) ----------------------------------------------------------
NUXT_PUBLIC_API_BASE=http://localhost:${NGINX_HTTP_PORT}/api/v1
NUXT_PUBLIC_APP_NAME=${APP_NAME}
